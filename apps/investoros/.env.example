# InvestorOS web app — environment variables

# --- Database (Postgres / Supabase) ---
DATABASE_URL="postgres://user:pass@host:5432/db?pgbouncer=true"
DIRECT_URL="postgres://user:pass@host:5432/db"

# --- App config ---
NEXT_PUBLIC_APP_URL="https://investoros.tech"
NEXT_PUBLIC_APP_DOMAIN="investoros.tech"
DEFAULT_TENANT_SLUG="pinnacle"

# --- Airtable (per-tenant tokens) ---
# Used by /geo dashboard server components to fetch live data from Airtable Geo Carpentry base.
# Token must have read access to base appAQpveuAec077jF (Contacts, Leads, Jobs, SEO_Audits, Content_Queue tables).
AIRTABLE_TOKEN_GEO=""

