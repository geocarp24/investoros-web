    <node id="El Secretario">
      <data key="d0">El Secretario</data>
      <data key="d1">concept</data>
      <data key="d2">El Secretario is an email management agent that monitors deals@pinnaclegroupwi.com, classifies emails, and automatically syncs leads to Airtable.&lt;SEP&gt;El Secretario is an email agent component of Alex Bot that monitors and processes emails, currently active on the VPS.&lt;SEP&gt;An email monitoring and classification system that processes incoming emails, archives Tracerfy emails, and integrates with Claude, Airtable, and Telegram.&lt;SEP&gt;El Secretario is an email monitoring system that uses IMAP, Claude classification, Airtable integration, and Telegram notifications to manage incoming emails.</data>
      <data key="d3">chunk-275ab3ea07b35b11481b16e0c66c1a8e&lt;SEP&gt;chunk-63ef4572aaf7092b6af41d899303a0d5&lt;SEP&gt;chunk-eb3c6f1b4d44514dab8d8aa921011d3f&lt;SEP&gt;chunk-68fbc7d74cbf3c49b18474190843517e</data>
